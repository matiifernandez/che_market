# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin & Contact
ADMIN_EMAIL=admin@yourdomain.com
CONTACT_EMAIL=support@yourdomain.com

# 2FA (TOTP)
# Use a stable 32+ char secret to encrypt OTP secrets
DEVISE_OTP_SECRET_KEY=replace_with_random_32_char_string

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email Configuration
MAILER_FROM_EMAIL=noreply@yourdomain.com
MAILER_FROM_NAME=Che Market

# SMTP Settings (for production)
# Common providers:
# - SendGrid: smtp.sendgrid.net, port 587
# - Mailgun: smtp.mailgun.org, port 587
# - Amazon SES: email-smtp.us-east-1.amazonaws.com, port 587
# - Postmark: smtp.postmarkapp.com, port 587
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=yourdomain.com
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS=true

# Application URL (for email links)
APP_HOST=yourdomain.com

# Background Jobs (Solid Queue)
# Number of worker processes (production)
JOB_CONCURRENCY=1
