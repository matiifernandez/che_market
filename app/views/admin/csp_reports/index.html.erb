<% content_for :page_title, "CSP Reports" %>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Fecha</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Directive</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Blocked URI</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Documento</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">User Agent</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @csp_reports.each do |report| %>
        <tr>
          <td class="px-4 py-3 text-sm text-gray-700"><%= l(report.occurred_at, format: :short) %></td>
          <td class="px-4 py-3 text-sm text-gray-700"><%= report.effective_directive || report.violated_directive %></td>
          <td class="px-4 py-3 text-sm text-gray-700 truncate max-w-xs"><%= report.blocked_uri %></td>
          <td class="px-4 py-3 text-sm text-gray-700 truncate max-w-xs"><%= report.document_uri %></td>
          <td class="px-4 py-3 text-xs text-gray-500 truncate max-w-xs"><%= report.user_agent %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
