<%= form_with model: [:admin, landing_page], local: true, class: "space-y-6" do |f| %>
  <% if landing_page.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg p-4">
      <p class="font-semibold mb-2">No se pudo guardar:</p>
      <ul class="list-disc list-inside text-sm space-y-1">
        <% landing_page.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="bg-white rounded-xl shadow-sm p-6 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :title, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :slug, "Slug", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :slug, placeholder: "yerba-mate-organica", class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
        <p class="text-xs text-gray-500 mt-1">Se usará como URL: /l/tu-slug</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :meta_title, "Meta title", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :meta_title, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :meta_description, "Meta description", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :meta_description, rows: 3, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :hero_title, "Hero title", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :hero_title, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :hero_subtitle, "Hero subtitle", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :hero_subtitle, rows: 3, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :hero_cta_text, "CTA text", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :hero_cta_text, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :hero_cta_url, "CTA URL", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_field :hero_cta_url, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div>
      <%= f.label :blocks_json, "Blocks (JSON)", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :blocks_json, value: landing_page.blocks_json, rows: 14, class: "w-full font-mono text-xs rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
      <div class="text-xs text-gray-500 mt-2 space-y-1">
        <p>Ejemplo:</p>
        <pre class="bg-gray-100 rounded-lg p-3 overflow-x-auto text-[11px]">[
  { "type": "text", "heading": "Por qué elegir yerba orgánica", "body": "Contenido..." },
  { "type": "feature_list", "heading": "Beneficios", "items": ["Sin pesticidas", "Sabor intenso"] },
  { "type": "product_grid", "heading": "Productos recomendados", "product_ids": [1, 2, 3] },
  { "type": "faq", "heading": "Preguntas frecuentes", "items": [{"q": "¿Envían a USA?", "a": "Sí, con tracking."}] },
  { "type": "cta", "heading": "¿Listo para comprar?", "body": "Encontrá tu yerba ideal.", "button_text": "Ver productos", "button_url": "/products" }
]</pre>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.check_box :published, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
      <%= f.label :published, "Publicada", class: "text-sm text-gray-700" %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit "Guardar", class: "px-5 py-2 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition" %>
    <%= link_to "Cancelar", admin_landing_pages_path, class: "px-5 py-2 rounded-lg bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition" %>
  </div>
<% end %>
