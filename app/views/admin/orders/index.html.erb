<% content_for :page_title, "Órdenes" %>

<div class="mb-4 flex items-center gap-2">
  <a href="<%= admin_orders_path %>" class="text-sm px-3 py-1.5 rounded-lg border <%= params[:risk] == "flagged" ? "border-gray-300 text-gray-600" : "border-indigo-600 text-indigo-600" %>">
    Todas
  </a>
  <a href="<%= admin_orders_path(risk: "flagged") %>" class="text-sm px-3 py-1.5 rounded-lg border <%= params[:risk] == "flagged" ? "border-indigo-600 text-indigo-600" : "border-gray-300 text-gray-600" %>">
    Con riesgo
  </a>
</div>

<div class="bg-white rounded-lg shadow overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden md:table-cell">Email</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden sm:table-cell">Riesgo</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hidden sm:table-cell">Fecha</th>
        <th class="px-4 lg:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @orders.each do |order| %>
        <tr>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
            <span class="flex items-center gap-2">
              #<%= order.id %>
              <% if order.viewed_at.nil? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-800 animate-pulse">
                  Nueva
                </span>
              <% end %>
            </span>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap text-sm text-gray-500 hidden md:table-cell">
            <%= order.email %>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
            <%= humanized_money_with_symbol(order.total) %>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap">
            <%= render "order_status_badge", status: order.status %>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap hidden sm:table-cell">
            <% if order.risk_flagged? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-yellow-100 text-yellow-800">
                <%= order.risk_level&.upcase || "FLAG" %>
              </span>
            <% else %>
              <span class="text-xs text-gray-400">OK</span>
            <% end %>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap text-sm text-gray-500 hidden sm:table-cell">
            <%= order.created_at.strftime("%d/%m/%Y") %>
          </td>
          <td class="px-4 lg:px-6 py-4 whitespace-nowrap text-sm">
            <a href="<%= admin_order_path(order) %>" class="text-indigo-600 hover:text-indigo-800">
              Ver
            </a>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @orders.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No hay órdenes todavía</p>
    </div>
  <% end %>
</div>

<%= render 'shared/pagination', pagy: @pagy %>
