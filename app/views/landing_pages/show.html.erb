<% content_for :meta_tags do %>
  <%= meta_tags(
    title: @landing_page.meta_title.presence || @landing_page.title,
    description: @landing_page.meta_description.presence || truncate(strip_tags(@landing_page.hero_subtitle.to_s), length: 160),
    type: "website"
  ) %>
<% end %>

<div class="bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900">
        <%= @landing_page.hero_title.presence || @landing_page.title %>
      </h1>
      <% if @landing_page.hero_subtitle.present? %>
        <p class="mt-4 text-lg text-gray-600 max-w-3xl mx-auto">
          <%= @landing_page.hero_subtitle %>
        </p>
      <% end %>
      <% hero_cta_url = @landing_page.safe_url(@landing_page.hero_cta_url) %>
      <% if @landing_page.hero_cta_text.present? && hero_cta_url.present? %>
        <div class="mt-6">
          <a href="<%= hero_cta_url %>" class="inline-flex items-center px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
            <%= @landing_page.hero_cta_text %>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12">
    <% @blocks.each do |block| %>
      <% case block["type"] %>
      <% when "text" %>
        <section class="bg-white rounded-2xl shadow-sm p-8">
          <% if block["heading"].present? %>
            <h2 class="text-2xl font-bold text-gray-900 mb-4"><%= block["heading"] %></h2>
          <% end %>
          <% if block["body"].present? %>
            <div class="prose max-w-none text-gray-700">
              <%= simple_format(block["body"]) %>
            </div>
          <% end %>
        </section>
      <% when "feature_list" %>
        <section class="bg-white rounded-2xl shadow-sm p-8">
          <% if block["heading"].present? %>
            <h2 class="text-2xl font-bold text-gray-900 mb-6"><%= block["heading"] %></h2>
          <% end %>
          <% if block["items"].is_a?(Array) %>
            <ul class="grid sm:grid-cols-2 gap-4 text-gray-700">
              <% block["items"].each do |item| %>
                <li class="flex gap-3">
                  <span class="text-indigo-600">✔</span>
                  <span><%= item %></span>
                </li>
              <% end %>
            </ul>
          <% end %>
        </section>
      <% when "faq" %>
        <section class="bg-white rounded-2xl shadow-sm p-8">
          <% if block["heading"].present? %>
            <h2 class="text-2xl font-bold text-gray-900 mb-6"><%= block["heading"] %></h2>
          <% end %>
          <% if block["items"].is_a?(Array) %>
            <div class="space-y-4">
              <% block["items"].each do |item| %>
                <details class="group rounded-lg border border-gray-200 p-4">
                  <summary class="cursor-pointer font-semibold text-gray-900">
                    <%= item["q"] %>
                  </summary>
                  <p class="mt-2 text-gray-600"><%= item["a"] %></p>
                </details>
              <% end %>
            </div>
          <% end %>
        </section>
      <% when "product_grid" %>
        <section class="bg-white rounded-2xl shadow-sm p-8">
          <% if block["heading"].present? %>
            <h2 class="text-2xl font-bold text-gray-900 mb-6"><%= block["heading"] %></h2>
          <% end %>
          <% products = Array(block["product_ids"]).map { |id| @products_by_id[id.to_i] }.compact %>
          <% if products.any? %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              <% products.each do |product| %>
                <a href="<%= product_path(product) %>" class="block bg-gray-50 rounded-xl overflow-hidden hover:shadow-md transition">
                  <div class="aspect-square bg-gray-100 flex items-center justify-center">
                    <% if product.images.attached? %>
                      <% image = product.images.first %>
                      <% if image.variable? %>
                        <%= image_tag image.variant(resize_to_limit: [600, 600]),
                          class: "w-full h-full object-cover",
                          loading: "lazy",
                          decoding: "async",
                          width: 600,
                          height: 600 %>
                      <% else %>
                        <%= image_tag image,
                          class: "w-full h-full object-cover",
                          loading: "lazy",
                          decoding: "async",
                          width: 600,
                          height: 600 %>
                      <% end %>
                    <% else %>
                      <span class="text-5xl">📦</span>
                    <% end %>
                  </div>
                  <div class="p-4">
                    <h3 class="font-semibold text-gray-900"><%= product.name %></h3>
                    <p class="text-indigo-600 font-bold mt-2"><%= humanized_money_with_symbol(product.price) %></p>
                  </div>
                </a>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-600"><%= t("products.no_products") %></p>
          <% end %>
        </section>
      <% when "cta" %>
        <section class="bg-indigo-600 text-white rounded-2xl shadow-sm p-8 text-center">
          <% if block["heading"].present? %>
            <h2 class="text-2xl font-bold"><%= block["heading"] %></h2>
          <% end %>
          <% if block["body"].present? %>
            <p class="mt-3 text-indigo-100"><%= block["body"] %></p>
          <% end %>
          <% button_url = @landing_page.safe_url(block["button_url"]) %>
          <% if block["button_text"].present? && button_url.present? %>
            <div class="mt-6">
              <a href="<%= button_url %>" class="inline-flex items-center px-6 py-3 rounded-lg bg-white text-indigo-700 font-semibold hover:bg-indigo-50 transition">
                <%= block["button_text"] %>
              </a>
            </div>
          <% end %>
        </section>
      <% end %>
    <% end %>
  </div>
</div>
