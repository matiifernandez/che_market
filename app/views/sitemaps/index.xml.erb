<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- Home page -->
  <url>
    <loc><%= root_url(locale: nil) %></loc>
    <%= sitemap_xhtml_links(:root_url) %>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Products index -->
  <url>
    <loc><%= products_url(locale: nil) %></loc>
    <%= sitemap_xhtml_links(:products_url) %>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Categories -->
  <% @categories.each do |category| %>
  <url>
    <loc><%= products_url(category: category.slug, locale: nil) %></loc>
    <%= sitemap_xhtml_links(:products_url, nil, { category: category.slug }) %>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>

  <!-- Individual products -->
  <% @products.each do |product| %>
  <url>
    <loc><%= product_url(product, locale: nil) %></loc>
    <%= sitemap_xhtml_links(:product_url, product) %>
    <lastmod><%= product.updated_at.strftime('%Y-%m-%d') %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>
  <% end %>

  <!-- Static Pages -->
  <url>
    <loc><%= terms_url(locale: nil) %></loc>
    <%= sitemap_xhtml_links(:terms_url) %>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc><%= privacy_url(locale: nil) %></loc>
    <%= sitemap_xhtml_links(:privacy_url) %>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>

  <!-- Landing Pages -->
  <% @landing_pages.each do |landing_page| %>
  <url>
    <loc><%= landing_page_url(landing_page.slug, locale: nil) %></loc>
    <%= sitemap_xhtml_links(:landing_page_url, landing_page.slug) %>
    <lastmod><%= landing_page.updated_at.strftime('%Y-%m-%d') %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>
</urlset>
